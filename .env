


SMS_GATEWAY_BASE_URL=https://api.sms-gate.app/3rdparty/v1
SMS_GATEWAY_USERNAME=
SMS_GATEWAY_PASSWORD=

DRY_RUN=false

# --- OTP behaviour ---------------------------------------------------------
OTP_LENGTH=6
OTP_TTL_SECONDS=300            # how long a code is valid (5 min)
OTP_MAX_ATTEMPTS=5            # wrong-code attempts before the code is killed
OTP_RESEND_COOLDOWN_SECONDS=60  # min seconds between resends to one number

# Secret used to HMAC-hash codes before storing them (so we never store
# plaintext OTPs). Change this to a long random string in production.
OTP_HASH_SECRET=change-me-to-a-long-random-string

# --- Storage ---------------------------------------------------------------
# Where to keep active OTP codes: "memory" (default, zero setup) or "postgres".
OTP_STORE=memory

# Neon / PostgreSQL connection string.
# Required only if OTP_STORE=postgres OR if you want the messages audit log.
# Example: postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://neondb_owner:npg_YjJ4PENnp1HT@ep-odd-water-aiut497i-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# --- Auth secrets (change in production) -----------------------------------
JWT_SECRET=dev-only-change-me-jwt-secret-string
JWT_EXPIRES_IN=7d
API_KEY_SECRET=dev-only-change-me-apikey-secret

# --- Operator (admin) account — created on first boot ----------------------
ADMIN_EMAIL=owner@gmail.com
ADMIN_PASSWORD=owner@123
ADMIN_NAME=Owner

# --- Razorpay (paste your keys to enable live payments) --------------------
# Get them from https://dashboard.razorpay.com/app/keys (test or live).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
BILLING_CURRENCY=INR

# --- Server ----------------------------------------------------------------
PORT=3001
CORS_ORIGIN=https://text-panda-frontend.vercel.app/
